<?xml version="1.0" encoding="UTF-8"?>
<!-- XML leaf changelog: rendered offline via `liquibase update-sql` when it
     changes (needs the Liquibase CLI in the job; no database). -->
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
  <changeSet id="3" author="ewen">
    <createIndex tableName="orders" indexName="idx_orders_customer">
      <column name="customer_id"/>
    </createIndex>
  </changeSet>
</databaseChangeLog>
